# ══════════════════════════════════════════════════════════════════════════════
# Customer Success Digital FTE — Environment Variables
#
# Usage:
#   cp .env.example .env
#   Fill in all values marked  ← REQUIRED
#   docker compose up --build
#
# docker-compose.yml overrides DATABASE_URL and KAFKA_BOOTSTRAP_SERVERS
# with container-internal hostnames automatically. The values below are
# used when running the app outside Docker (e.g. local dev / tests).
# ══════════════════════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL


# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme       # ← REQUIRED  change before deploying
POSTGRES_DB=customer_success
POSTGRES_PORT=5432

# Used when running outside Docker. Compose overrides this automatically.
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/customer_success

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false


# ── Kafka ─────────────────────────────────────────────────────────────────────
# Used when running outside Docker. Compose overrides this automatically.
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_EXTERNAL_PORT=9093         # Port exposed to the Docker host for tooling

KAFKA_TOPIC_INBOUND=cs-fte.messages.inbound
KAFKA_TOPIC_OUTBOUND=cs-fte.messages.outbound
KAFKA_TOPIC_ESCALATIONS=cs-fte.tickets.escalations
KAFKA_TOPIC_DLQ=cs-fte.messages.dlq
KAFKA_CONSUMER_GROUP=cs-fte-worker


# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...            # ← REQUIRED
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536


# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-min-32-chars   # ← REQUIRED
INTERNAL_API_KEY=replace-with-another-random-string         # ← REQUIRED
API_PORT=8000


# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed origins
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]


# ── Gmail (Cloud Pub/Sub webhook channel) ─────────────────────────────────────
# OAuth credential files are mounted into the container at /app/credentials/
# Run the OAuth consent flow locally first to generate gmail_token.json.
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.json
GMAIL_POLL_INTERVAL_SECONDS=60


# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=             # ← REQUIRED for WhatsApp channel
WHATSAPP_ACCESS_TOKEN=                # ← REQUIRED for WhatsApp channel
WHATSAPP_VERIFY_TOKEN=                # ← REQUIRED  set in Meta Developer dashboard
WHATSAPP_APP_SECRET=                  # ← REQUIRED  for X-Hub-Signature-256 verification


# ── SMTP (outbound email fallback & notification emails) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true


# ── Notifications (Step 7) ────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=                    # Slack incoming webhook for team alerts
SUPPORT_TEAM_EMAIL=                   # Support inbox for escalation/SLA emails
APP_BASE_URL=http://localhost:8000    # Public URL — used in survey links & admin URLs


# ── SLA & escalation thresholds ───────────────────────────────────────────────
ESCALATION_SLA_HOURS=4
SLA_MONITOR_INTERVAL_MINUTES=15
SURVEY_RESPONSE_WINDOW_HOURS=48
AUTO_ESCALATION_CONFIDENCE_THRESHOLD=0.6
MAX_AI_RETRIES_BEFORE_ESCALATION=3


# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Optional: Enable hybrid orchestration with Claude Agent SDK
ANTHROPIC_API_KEY=                # ← REQUIRED for Claude features
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_ENABLED=false              # Set to true to enable Claude integration


# ── A2A Protocol ──────────────────────────────────────────────────────────────
# Inter-FTE collaboration protocol
FTE_ID=cs-fte-001                 # Unique identifier for this FTE instance
A2A_API_KEY=                      # ← REQUIRED for A2A authentication
A2A_ENABLED=true                  # Enable A2A protocol endpoints


# ── Dapr Workflows ────────────────────────────────────────────────────────────
# Dapr configuration for durable workflows
DAPR_GRPC_ENDPOINT=localhost:50001
DAPR_HTTP_ENDPOINT=http://localhost:3500
DAPR_PUBSUB_NAME=cs-pubsub
DAPR_STATE_STORE=cs-state
DAPR_WORKFLOW_RUNTIME=workflow-runtime


# ── MCP (Model Context Protocol) ──────────────────────────────────────────────
# MCP server configurations (optional)
MCP_ENABLED=false
MCP_SERVER_IDS=                   # Comma-separated list of MCP server IDs

# Filesystem MCP (optional)
MCP_FILESYSTEM_PATH=              # Path to expose via filesystem MCP

# PostgreSQL MCP (optional)
MCP_POSTGRES_CONNECTION_STRING=   # PostgreSQL connection for MCP

# GitHub MCP (optional)
MCP_GITHUB_TOKEN=                 # GitHub token for GitHub MCP

# Slack MCP (optional)
MCP_SLACK_BOT_TOKEN=              # Slack bot token for Slack MCP


# ── gVisor Sandbox ────────────────────────────────────────────────────────────
# Sandbox configuration (optional, for enhanced security)
SANDBOX_ENABLED=false
SANDBOX_RUNTIME=runsc
