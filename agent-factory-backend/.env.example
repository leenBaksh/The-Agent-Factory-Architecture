# Agent Factory Backend - Environment Configuration

# Application
APP_NAME="Agent Factory Backend"
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8003

# A2A Protocol
A2A_ENABLED=true
A2A_API_KEY=change-me-in-production

# FTE URLs
CUSTOMER_SUCCESS_FTE_URL=http://localhost:8001

# Authentication & Security
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production-use-env-var
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
BCRYPT_ROUNDS=12
